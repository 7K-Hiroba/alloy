{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "alloy base chart values",
  "type": "object",
  "properties": {
    "alloy": {
      "type": "object",
      "description": "Upstream grafana/alloy chart values (nested under dependency name)",
      "properties": {
        "image": {
          "type": "object",
          "required": ["repository"],
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
            "tag": { "type": "string" }
          },
          "additionalProperties": true
        },
        "controller": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["daemonset", "deployment", "statefulset"] },
            "replicas": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": true
        },
        "service": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] }
          },
          "additionalProperties": true
        },
        "alloy": {
          "type": "object",
          "properties": {
            "enableReporting": { "type": "boolean" },
            "resources": { "type": "object" },
            "mounts": {
              "type": "object",
              "properties": {
                "varlog": { "type": "boolean" },
                "dockercontainers": { "type": "boolean" }
              },
              "additionalProperties": true
            },
            "envFrom": { "type": "array" },
            "extraEnv": { "type": "array" }
          },
          "additionalProperties": true
        },
        "serviceAccount": {
          "type": "object",
          "properties": {
            "create": { "type": "boolean" }
          },
          "additionalProperties": true
        },
        "rbac": {
          "type": "object",
          "properties": {
            "create": { "type": "boolean" }
          },
          "additionalProperties": true
        },
        "configReloader": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "resources": { "type": "object" }
          },
          "additionalProperties": true
        },
        "serviceMonitor": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          },
          "additionalProperties": true
        },
        "ingress": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "gateway": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "hostnames": { "type": "array", "items": { "type": "string" } },
        "parentRefs": { "type": "array" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
