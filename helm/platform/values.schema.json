{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "global"
  ],
  "properties": {
    "global": {
      "type": "object",
      "required": [
        "appName"
      ],
      "properties": {
        "appName": {
          "type": "string",
          "minLength": 1
        },
        "baseInstance": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "postgres": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "provider": {
          "type": "string",
          "enum": [
            "cnpg"
          ]
        },
        "instances": {
          "type": "integer",
          "minimum": 1
        },
        "storage": {
          "type": "object",
          "properties": {
            "size": {
              "type": "string",
              "pattern": "^[0-9]+(Mi|Gi|Ti)$"
            },
            "storageClass": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "resources": {
          "type": "object",
          "properties": {
            "limits": {
              "type": "object",
              "properties": {
                "cpu": {
                  "type": "string"
                },
                "memory": {
                  "type": "string"
                }
              },
              "additionalProperties": true
            },
            "requests": {
              "type": "object",
              "properties": {
                "cpu": {
                  "type": "string"
                },
                "memory": {
                  "type": "string"
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "imageName": {
          "type": "string"
        },
        "database": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "backup": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "schedule": {
              "type": "string"
            },
            "retentionPolicy": {
              "type": "string"
            },
            "bucketName": {
              "type": "string"
            },
            "endpoint": {
              "type": "string"
            },
            "credentialsSecret": {
              "type": "object",
              "required": [
                "name"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "accessKeyKey": {
                  "type": "string"
                },
                "secretKeyKey": {
                  "type": "string"
                },
                "regionKey": {
                  "type": "string"
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "s3": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "provider": {
          "type": "string",
          "enum": [
            "crossplane",
            "garage"
          ]
        },
        "crossplane": {
          "type": "object",
          "properties": {
            "region": {
              "type": "string"
            },
            "providerConfigRef": {
              "type": "string"
            },
            "lifecycle": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "expirationDays": {
                  "type": "integer",
                  "minimum": 1
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "garage": {
          "type": "object",
          "properties": {
            "clusterRef": {
              "type": "string"
            },
            "clusterRefNamespace": {
              "type": "string"
            },
            "quotas": {
              "type": "object",
              "properties": {
                "maxSize": {
                  "type": "string"
                },
                "maxObjects": {
                  "type": "integer"
                }
              },
              "additionalProperties": true
            },
            "website": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "indexDocument": {
                  "type": "string"
                },
                "errorDocument": {
                  "type": "string"
                }
              },
              "additionalProperties": true
            },
            "lifecycle": {
              "type": "object",
              "properties": {
                "rules": {
                  "type": "array"
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "buckets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "acl": {
                "type": "string"
              },
              "region": {
                "type": "string"
              },
              "providerConfigRef": {
                "type": "string"
              },
              "clusterRef": {
                "type": "string"
              },
              "clusterRefNamespace": {
                "type": "string"
              },
              "quotas": {
                "type": "object",
                "additionalProperties": true
              },
              "website": {
                "type": "object",
                "additionalProperties": true
              },
              "lifecycle": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "externalSecrets": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "refreshInterval": {
          "type": "string"
        },
        "storeRef": {
          "type": "object",
          "required": [
            "name",
            "kind"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "enum": [
                "SecretStore",
                "ClusterSecretStore"
              ]
            }
          },
          "additionalProperties": true
        },
        "data": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "secretKey",
              "remoteKey"
            ],
            "properties": {
              "secretKey": {
                "type": "string"
              },
              "remoteKey": {
                "type": "string"
              },
              "property": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "dataFrom": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "extract": {
                "type": "object",
                "properties": {
                  "key": {
                    "type": "string"
                  }
                },
                "additionalProperties": true
              }
            },
            "additionalProperties": true
          }
        },
        "target": {
          "type": "object",
          "properties": {
            "template": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "observability": {
      "type": "object",
      "properties": {
        "serviceMonitor": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "additionalLabels": {
              "type": "object",
              "additionalProperties": true
            },
            "port": {
              "type": "string"
            },
            "path": {
              "type": "string"
            },
            "interval": {
              "type": "string"
            },
            "scrapeTimeout": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "grafanaDashboard": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "folderLabel": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "prometheusRules": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "groups": {
              "type": "array"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "hiroba-platform-lib": {
      "description": "Subchart values override slot — empty by default; library charts have no consumable values.",
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
